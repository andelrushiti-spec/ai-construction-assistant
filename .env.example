# OpenAI API Key (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Flask Secret Key (Change in production)
SECRET_KEY=your-secret-key-here

# Database URL (Optional - defaults to SQLite)
# DATABASE_URL=sqlite:///construction_assistant.db
# DATABASE_URL=postgresql://user:password@localhost/construction_db

# Debug Mode
DEBUG=False

# Tesseract Path (Update based on your OS)
# macOS (Homebrew): /usr/local/bin/tesseract or /opt/homebrew/bin/tesseract
# Linux: /usr/bin/tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=/usr/local/bin/tesseract

# Encryption Key (Optional - for AES encryption of embeddings)
# ENCRYPTION_KEY=your-encryption-key-here

# Log Level
LOG_LEVEL=INFO
